% Internal booleans (set by key processing below)
\bool_new:N \l_adenc_color_bool        \bool_set_false:N \l_adenc_color_bool
\bool_new:N \l_adenc_boxed_bool        \bool_set_false:N \l_adenc_boxed_bool
\bool_new:N \l_adenc_hideproofs_bool   \bool_set_false:N \l_adenc_hideproofs_bool
\bool_new:N \l_adenc_hidemarkings_bool \bool_set_false:N \l_adenc_hidemarkings_bool
\bool_new:N \l_adenc_workingpaper_bool \bool_set_false:N \l_adenc_workingpaper_bool
\bool_new:N \l_adenc_fancyqed_bool     \bool_set_true:N  \l_adenc_fancyqed_bool
\bool_new:N \l_adenc_header_bool       \bool_set_true:N  \l_adenc_header_bool
\bool_new:N \l_adenc_sectionpage_bool  \bool_set_true:N  \l_adenc_sectionpage_bool
\bool_new:N \l_adenc_index_bool        \bool_set_false:N \l_adenc_index_bool

\keys_define:nn { adenc } {
  % theorembox: choice key controlling box style and color
  % none  = plain amsthm styles, no color (default)
  % plain = tcolorbox boxes, no color
  % color = tcolorbox boxes + color
  theorembox .choices:nn = { none, plain, color } {
    \int_case:nn { \l_keys_choice_int } {
      { 1 } { \bool_set_false:N \l_adenc_boxed_bool  \bool_set_false:N \l_adenc_color_bool }
      { 2 } { \bool_set_true:N  \l_adenc_boxed_bool  \bool_set_false:N \l_adenc_color_bool }
      { 3 } { \bool_set_true:N  \l_adenc_boxed_bool  \bool_set_true:N  \l_adenc_color_bool }
    }
  },
  theorembox .default:n = none,
  % \usepackage[hideproofs]{adenc} to hide everything in the proof environment.
  hideproofs   .bool_set:N = \l_adenc_hideproofs_bool,   hideproofs   .default:n = true,
  % \usepackage[hidemarkings]{adenc} to hide all \markabove and \markbelow annotations.
  hidemarkings .bool_set:N = \l_adenc_hidemarkings_bool, hidemarkings .default:n = true,
  % \usepackage[workingpaper]{adenc} for wider margins (todonotes) and draft watermark.
  workingpaper .bool_set:N = \l_adenc_workingpaper_bool, workingpaper .default:n = true,
  % \usepackage[index]{adenc} to enable automatic indexing of \vocab terms.
  index        .bool_set:N = \l_adenc_index_bool,        index        .default:n = true,
  % \usepackage[fancyqed=false]{adenc} to use the default qed symbol.
  fancyqed     .bool_set:N = \l_adenc_fancyqed_bool,     fancyqed     .default:n = true,
  % \usepackage[header=false]{adenc} to disable the running section header.
  header       .bool_set:N = \l_adenc_header_bool,       header       .default:n = true,
  % \usepackage[clearsection=false]{adenc} to disable new-page at each section.
  clearsection .bool_set:N = \l_adenc_sectionpage_bool,  clearsection .default:n = true,
}

\ProcessKeysOptions { adenc }

% Bridge macros: valid LaTeX2e csnames callable outside \ExplSyntaxOn
\cs_new_protected:Npn \adencIfColor        #1#2 { \bool_if:NTF \l_adenc_color_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfBoxed        #1#2 { \bool_if:NTF \l_adenc_boxed_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfHideproofs   #1#2 { \bool_if:NTF \l_adenc_hideproofs_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfHidemarkings #1#2 { \bool_if:NTF \l_adenc_hidemarkings_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfWorkingpaper #1#2 { \bool_if:NTF \l_adenc_workingpaper_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfFancyqed     #1#2 { \bool_if:NTF \l_adenc_fancyqed_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfHeader       #1#2 { \bool_if:NTF \l_adenc_header_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfSectionpage  #1#2 { \bool_if:NTF \l_adenc_sectionpage_bool {#1}{#2} }
\cs_new_protected:Npn \adencIfIndex        #1#2 { \bool_if:NTF \l_adenc_index_bool {#1}{#2} }

