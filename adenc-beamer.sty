\clist_map_inline:nn {A,B,C,D,E,F,K,L,M,P,R,S,T,U,V}
{
  \cs_new:cpn { s#1 } { \mathscr{#1} }
}
% \fX -> \mathfrak{X}  (excluding I to avoid \fi TeX primitive clash)
\clist_map_inline:nn {A,B,C,D,E,F,G,H,J,K,L,M,N,O,P,Q,R,S,T,U,V,W,X,Y,Z}
{
  \cs_new:cpn { f#1 } { \mathfrak{#1} }
}
